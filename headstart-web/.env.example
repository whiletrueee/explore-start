# Google Maps JavaScript API — get these from Google Cloud Console (see README).
# Restrict the key to the Maps JavaScript API + your domains (localhost for dev).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key_here
# Optional: a vector Map ID for AdvancedMarkers + custom styling. Leave blank to use Google's DEMO_MAP_ID in dev.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# headstart-admin API. Leave blank to fall back to bundled /public/data/*.json fixtures.
# Production demo: https://headstart-admin-production.up.railway.app/api
NEXT_PUBLIC_API_BASE=
