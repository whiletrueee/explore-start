{
  "version": 3,
  "note": "Field Atlas canonical data architecture. Three levels: creator -> guide -> gem. Some columns are intentionally blank now and bulk-filled in later PRs (marked fill_later).",

  "levels": {
    "creator": {
      "id": "creator handle (primary key, e.g. dotzsoh-singapore)",
      "name": "display name",
      "tag": "short descriptor (e.g. 'Singapore')",
      "color": "hex accent",
      "n_gems": "count of gems",
      "guide_ids": "ids of this creator's guides (may be empty -> creator has no guide)"
    },

    "guide": {
      "id": "creator + city slug (primary key)",
      "creator": "FK -> creator.id",
      "label": "guide title (city, or destination-as-city like Florida)",
      "level": "city | destination",
      "destination": "country/destination key",
      "cities": "list of city names this guide spans",
      "n_gems": "count",
      "lens": "local | tourist  (derived from member themes)",
      "blurb": "one-line guide description (placeholder now, editorial later)",
      "hero_gem_id": "FK -> gem.id chosen as the guide hero",
      "hero_image": "guide hero image url  [fill_later]"
    },

    "gem": {
      "identity":  ["id", "name", "hook", "why", "confidence"],
      "taxonomy":  ["category", "subcategory", "themes"],
      "location":  ["destination", "region", "city", "area", "location_text", "lat", "lng", "scope"],
      "links":     ["website", "source_reel", "source_reels"],
      "headout":   ["headout_tgid", "headout_poi", "headout_subcategory_id", "headout_collection_id"],
      "temporal":  ["date_info"],
      "price":     ["price_text"],
      "provenance":["creator", "reel_id", "saved_from"],
      "media":     ["media_brief", "media_url"],
      "derived":   ["guide_id"]
    }
  },

  "fill_later": ["lat", "lng", "media_url", "website (bulk enrich)",
                 "headout_tgid", "headout_poi", "headout_subcategory_id", "headout_collection_id",
                 "guide.hero_image"],

  "dropped_from_v2": ["hours (profile flag + field) — removed entirely", "_city (internal alias)"],

  "headout_columns": {
    "headout_tgid": "Headout Tour Group ID for Book-on-Headout deeplink",
    "headout_poi": "yes | no — is this gem a Headout Point of Interest",
    "headout_subcategory_id": "Headout sub-category id",
    "headout_collection_id": "Headout collection id"
  },

  "taxonomy": {
    "eat": ["restaurant", "cafe", "bakery-dessert", "street-food", "food-hall", "market", "fine-dining"],
    "drink": ["cocktail-bar", "wine-bar", "brewery", "coffee", "rooftop", "speakeasy"],
    "stay": ["hotel", "boutique-hotel", "resort", "hostel", "unique-stay"],
    "see-do": ["landmark", "museum-gallery", "experience", "tour", "show", "class-workshop", "nightlife"],
    "shop": ["boutique", "market", "mall", "bookstore", "specialty"],
    "view": ["observation-deck", "skyline", "scenic-overlook", "photo-spot"],
    "nature": ["beach", "park-garden", "hike-trail", "waterfall", "island", "natural-landmark"],
    "plan": ["budget-hack", "when-to-go", "what-to-skip", "transit", "packing", "booking", "points-miles"],
    "itinerary": ["day-trip", "multi-day", "neighborhood-walk", "food-crawl", "weekend"],
    "list": ["roundup", "ranking", "themed-collection"]
  },

  "profiles_note": "Per-type metadata expectations (drives which fields a card/popup surfaces). 'hours' removed in v3. flags: loc, addr, web, book, date, price; scope: point|multi|city|none.",
